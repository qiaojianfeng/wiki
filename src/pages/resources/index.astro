---
import Layout from '../../layouts/Layout.astro';
import resourcesData from '../../content/resources/resources.json';

const { categories } = resourcesData;

const totalResources = categories.reduce((acc, cat) => acc + cat.resources.length, 0);
---

<Layout title="资源收藏" description="有价值的技术站点、工具、学习资源">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="section-title">资源收藏</h1>
      <p class="text-gray-400 max-w-2xl mx-auto">
        整理收集的一些有价值的技术站点、开发工具和学习资源
      </p>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-12 max-w-2xl mx-auto">
      <div class="glass-card p-4 text-center">
        <div class="text-3xl font-bold text-white">{categories.length}</div>
        <div class="text-sm text-gray-400">分类</div>
      </div>
      <div class="glass-card p-4 text-center">
        <div class="text-3xl font-bold text-primary-400">{totalResources}</div>
        <div class="text-sm text-gray-400">资源</div>
      </div>
      <div class="glass-card p-4 text-center">
        <div class="text-3xl font-bold text-accent-purple">
          {new Set(categories.flatMap(c => c.resources.flatMap(r => r.tags))).size}
        </div>
        <div class="text-sm text-gray-400">标签</div>
      </div>
    </div>

    <!-- Resources by Category -->
    <div class="space-y-12">
      {categories.map((category, catIndex) => (
        <section>
          <!-- Category Header -->
          <div class="flex items-center space-x-3 mb-6">
            <span class="text-3xl">{category.icon}</span>
            <h2 class="text-2xl font-bold text-white">{category.name}</h2>
            <span class="tag text-sm">{category.resources.length}</span>
          </div>
          
          <!-- Resources Grid -->
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {category.resources.map((resource, index) => (
              <a 
                href={resource.url}
                target="_blank"
                rel="noopener noreferrer"
                class="glass-card p-5 group hover:border-primary-500/50 transition-all"
                style={`animation-delay: ${(catIndex * 0.1) + (index * 0.05)}s`}
              >
                <div class="flex items-start justify-between mb-3">
                  <h3 class="text-lg font-semibold text-white group-hover:text-primary-400 transition-colors">
                    {resource.name}
                  </h3>
                  <svg class="w-5 h-5 text-gray-500 group-hover:text-primary-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </div>
                
                <p class="text-gray-400 text-sm mb-3 line-clamp-2">
                  {resource.description}
                </p>
                
                <div class="flex flex-wrap gap-2">
                  {resource.tags.map(tag => (
                    <span class="tag text-xs">{tag}</span>
                  ))}
                </div>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>

    <!-- Submit Resource -->
    <div class="mt-16 text-center">
      <div class="glass-card p-8 max-w-2xl mx-auto">
        <div class="text-4xl mb-4">💡</div>
        <h3 class="text-xl font-semibold text-white mb-2">有推荐的资源？</h3>
        <p class="text-gray-400 mb-4">
          如果你发现了有价值的技术资源，欢迎通过 GitHub 提交 PR 来丰富这个列表
        </p>
        <a 
          href="https://github.com/username/solo-coder-site"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center space-x-2 px-6 py-3 bg-primary-600 hover:bg-primary-500 text-white rounded-lg font-medium transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
          </svg>
          <span>在 GitHub 上提交</span>
        </a>
      </div>
    </div>
  </div>
</Layout>
