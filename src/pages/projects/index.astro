---
import Layout from '../../layouts/Layout.astro';
import projectsData from '../../content/projects/projects.json';
import { statusConfig } from '../../data/projects';

const { projects } = projectsData;
---

<Layout title="项目展示" description="个人开发的应用、工具、开源项目">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="section-title">项目展示</h1>
      <p class="text-gray-400 max-w-2xl mx-auto">
        这里展示了我开发的一些应用、工具和开源项目，每一个都是学习和实践的结晶
      </p>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12 max-w-3xl mx-auto">
      <div class="pixel-card p-4 text-center">
        <div class="text-3xl font-bold font-mono text-primary-400">{projects.length}</div>
        <div class="text-sm font-mono text-gray-400">总项目</div>
      </div>
      <div class="pixel-card p-4 text-center">
        <div class="text-3xl font-bold font-mono text-accent-green">
          {projects.filter(p => p.status === 'active').length}
        </div>
        <div class="text-sm font-mono text-gray-400">进行中</div>
      </div>
      <div class="pixel-card p-4 text-center">
        <div class="text-3xl font-bold font-mono text-accent-purple">
          {projects.filter(p => p.status === 'completed').length}
        </div>
        <div class="text-sm font-mono text-gray-400">已完成</div>
      </div>
      <div class="pixel-card p-4 text-center">
        <div class="text-3xl font-bold font-mono text-primary-400">
          {projects.filter(p => p.demo).length}
        </div>
        <div class="text-sm font-mono text-gray-400">有演示</div>
      </div>
    </div>

    <!-- Projects Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project, index) => (
        <div class="pixel-card overflow-hidden group animate-fade-in-pixel" style={`animation-delay: ${index * 0.1}s`}>
          <div class="p-6">
            <!-- Header -->
            <div class="flex items-start justify-between mb-4">
              <div class="flex items-center space-x-3">
                <span class="text-4xl geek-text">{project.icon}</span>
                <div>
                  <h3 class="text-xl font-bold font-mono text-white group-hover:text-primary-400 transition-colors">
                    {project.name}
                  </h3>
                  <span class={`tag text-xs mt-1 ${statusConfig[project.status as keyof typeof statusConfig]?.class || 'tag'}`}>
                    {statusConfig[project.status as keyof typeof statusConfig]?.label || project.status}
                  </span>
                </div>
              </div>
            </div>
            
            <!-- Description -->
            <p class="text-gray-400 text-sm mb-4 line-clamp-2 font-mono">
              {project.description}
            </p>
            
            <!-- Tags -->
            <div class="flex flex-wrap gap-2 mb-4">
              {project.tags.map(tag => (
                <span class="tag text-xs">{tag}</span>
              ))}
            </div>
            
            <!-- Links -->
            <div class="flex items-center space-x-3">
              <a 
                href={project.github} 
                target="_blank" 
                rel="noopener noreferrer"
                class="pixel-button bg-gray-900 text-primary-400 hover:bg-gray-800 text-xs px-3 py-1"
              >
                源码
              </a>
              
              {project.demo && (
                <a 
                  href={project.demo} 
                  target="_blank" 
                  rel="noopener noreferrer"
                  class="pixel-button text-xs px-3 py-1"
                >
                  演示
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>
