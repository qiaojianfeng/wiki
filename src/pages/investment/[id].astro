---
import Layout from '../../layouts/Layout.astro';
import articlesData from '../../content/investment/articles.json';
import { categoryColors } from '../../data/investment';

export function getStaticPaths() {
  return articlesData.articles.map(article => ({
    params: { id: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;

// 简单的 Markdown 渲染函数
function renderMarkdown(content: string) {
  return content
    .replace(/## (.*)/g, '<h2 class="text-2xl font-bold text-white mt-8 mb-4">$1</h2>')
    .replace(/\*\*(.*?)\*\*/g, '<strong class="text-white font-semibold">$1</strong>')
    .replace(/\d+\. \*\*(.*?)\*\*/g, '<div class="flex items-start mb-2"><span class="text-primary-400 mr-2">•</span><span>$1</span></div>')
    .replace(/- (.*)/g, '<div class="flex items-start mb-2"><span class="text-gray-500 mr-2">-</span><span>$1</span></div>')
    .replace(/\n\n/g, '</p><p class="mb-4">')
    .replace(/^/, '<p class="mb-4">')
    .replace(/$/, '</p>');
}
---

<Layout title={article.title} description={article.description}>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Back button -->
    <a href="/investment" class="inline-flex items-center text-gray-400 hover:text-white mb-8 transition-colors">
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      返回列表
    </a>

    <!-- Article Header -->
    <header class="mb-8">
      <div class="flex items-center space-x-3 mb-4">
        <span class={`tag ${categoryColors[article.category] || ''}`}>
          {article.category}
        </span>
        <div class="flex items-center text-sm text-gray-400">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          {new Date(article.date).toLocaleDateString('zh-CN')}
        </div>
      </div>
      
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">
        {article.title}
      </h1>
      
      <p class="text-gray-400 text-lg">
        {article.description}
      </p>
    </header>

    <!-- Article Content -->
    <div class="prose prose-invert prose-lg max-w-none text-gray-300">
      <Fragment set:html={renderMarkdown(article.content)} />
    </div>

    <!-- Tags -->
    <div class="flex flex-wrap gap-2 mt-8">
      {article.tags.map(tag => (
        <span class="tag">{tag}</span>
      ))}
    </div>

    <!-- Article Footer -->
    <footer class="mt-12 pt-8 border-t border-gray-800">
      <div class="flex items-center justify-between">
        <div class="text-gray-400 text-sm">
          感谢阅读
        </div>
        <a href="/investment" class="inline-flex items-center text-primary-400 hover:text-primary-300 transition-colors">
          查看更多文章
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </footer>

    <!-- Disclaimer -->
    <div class="mt-8 p-4 glass rounded-lg">
      <div class="flex items-start space-x-3">
        <svg class="w-5 h-5 text-accent-orange flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <div class="text-sm text-gray-400">
          <strong class="text-gray-300">免责声明：</strong>
          本文内容仅为个人投资心得分享，不构成任何投资建议。股市有风险，投资需谨慎。
        </div>
      </div>
    </div>
  </article>
</Layout>
