[["Map",1,2,7,8],"meta::meta",["Map",3,4,5,6],"astro-version","5.18.1","astro-config-digest","{\"root\":{},\"srcDir\":{},\"publicDir\":{},\"outDir\":{},\"cacheDir\":{},\"site\":\"https://solocoder.dev\",\"compressHTML\":true,\"base\":\"/\",\"trailingSlash\":\"ignore\",\"output\":\"static\",\"scopedStyleStrategy\":\"attribute\",\"build\":{\"format\":\"directory\",\"client\":{},\"server\":{},\"assets\":\"_astro\",\"serverEntry\":\"entry.mjs\",\"redirects\":true,\"inlineStylesheets\":\"auto\",\"concurrency\":1},\"server\":{\"open\":false,\"host\":false,\"port\":4321,\"streaming\":true,\"allowedHosts\":[]},\"redirects\":{},\"image\":{\"endpoint\":{\"route\":\"/_image\"},\"service\":{\"entrypoint\":\"astro/assets/services/sharp\",\"config\":{}},\"domains\":[],\"remotePatterns\":[],\"responsiveStyles\":false},\"devToolbar\":{\"enabled\":true},\"markdown\":{\"syntaxHighlight\":{\"type\":\"shiki\",\"excludeLangs\":[\"math\"]},\"shikiConfig\":{\"langs\":[],\"langAlias\":{},\"theme\":\"github-dark\",\"themes\":{},\"wrap\":false,\"transformers\":[]},\"remarkPlugins\":[],\"rehypePlugins\":[],\"remarkRehype\":{},\"gfm\":true,\"smartypants\":true},\"security\":{\"checkOrigin\":true,\"allowedDomains\":[],\"actionBodySizeLimit\":1048576},\"env\":{\"schema\":{},\"validateSecrets\":false},\"experimental\":{\"clientPrerender\":false,\"contentIntellisense\":false,\"headingIdCompat\":false,\"preserveScriptOrder\":false,\"liveContentCollections\":false,\"csp\":false,\"staticImportMetaEnv\":false,\"chromeDevtoolsWorkspace\":false,\"failOnPrerenderConflict\":false,\"svgo\":false},\"legacy\":{\"collections\":false}}","coding",["Map",9,10,43,44],"astro-guide",{"id":9,"data":11,"body":19,"filePath":20,"digest":21,"rendered":22,"legacyId":42},{"title":12,"description":13,"date":14,"tags":15},"Astro 入门指南","为什么我选择 Astro 构建静态站点","2024-03-20",[16,17,18],"Astro","Static Site","Web Development","# Astro 入门指南\n\nAstro 是一个现代化的静态站点生成器，它让我重新思考了如何构建 Web 应用。\n\n## 为什么选择 Astro？\n\n1. **零 JavaScript 默认** - 页面加载速度极快\n2. **群岛架构** - 只在需要的地方使用 JavaScript\n3. **框架无关** - 支持 React、Vue、Svelte 等\n\n## 快速开始\n\n```bash\nnpm create astro@latest\n```\n\n## 我的使用体验\n\n使用 Astro 构建这个个人站点后，我深刻体会到了它的优势：\n\n- 构建速度非常快\n- 生成的页面体积很小\n- Markdown 支持开箱即用\n\n## 结语\n\n如果你正在寻找一个简单高效的静态站点方案，Astro 值得一试。","src/content/coding/astro-guide.md","b767492875554ee3",{"html":23,"metadata":24},"\u003Ch1 id=\"astro-入门指南\">Astro 入门指南\u003C/h1>\n\u003Cp>Astro 是一个现代化的静态站点生成器，它让我重新思考了如何构建 Web 应用。\u003C/p>\n\u003Ch2 id=\"为什么选择-astro\">为什么选择 Astro？\u003C/h2>\n\u003Col>\n\u003Cli>\u003Cstrong>零 JavaScript 默认\u003C/strong> - 页面加载速度极快\u003C/li>\n\u003Cli>\u003Cstrong>群岛架构\u003C/strong> - 只在需要的地方使用 JavaScript\u003C/li>\n\u003Cli>\u003Cstrong>框架无关\u003C/strong> - 支持 React、Vue、Svelte 等\u003C/li>\n\u003C/ol>\n\u003Ch2 id=\"快速开始\">快速开始\u003C/h2>\n\u003Cpre class=\"astro-code github-dark\" style=\"background-color:#24292e;color:#e1e4e8; overflow-x: auto;\" tabindex=\"0\" data-language=\"bash\">\u003Ccode>\u003Cspan class=\"line\">\u003Cspan style=\"color:#B392F0\">npm\u003C/span>\u003Cspan style=\"color:#9ECBFF\"> create\u003C/span>\u003Cspan style=\"color:#9ECBFF\"> astro@latest\u003C/span>\u003C/span>\u003C/code>\u003C/pre>\n\u003Ch2 id=\"我的使用体验\">我的使用体验\u003C/h2>\n\u003Cp>使用 Astro 构建这个个人站点后，我深刻体会到了它的优势：\u003C/p>\n\u003Cul>\n\u003Cli>构建速度非常快\u003C/li>\n\u003Cli>生成的页面体积很小\u003C/li>\n\u003Cli>Markdown 支持开箱即用\u003C/li>\n\u003C/ul>\n\u003Ch2 id=\"结语\">结语\u003C/h2>\n\u003Cp>如果你正在寻找一个简单高效的静态站点方案，Astro 值得一试。\u003C/p>",{"headings":25,"localImagePaths":39,"remoteImagePaths":40,"frontmatter":11,"imagePaths":41},[26,29,33,35,37],{"depth":27,"slug":28,"text":12},1,"astro-入门指南",{"depth":30,"slug":31,"text":32},2,"为什么选择-astro","为什么选择 Astro？",{"depth":30,"slug":34,"text":34},"快速开始",{"depth":30,"slug":36,"text":36},"我的使用体验",{"depth":30,"slug":38,"text":38},"结语",[],[],[],"astro-guide.md","first-post",{"id":43,"data":45,"body":53,"filePath":54,"digest":55,"rendered":56,"legacyId":76},{"title":46,"description":47,"date":48,"tags":49},"构建高性能的 React 应用","分享一些 React 性能优化的实践经验","2024-03-15",[50,51,52],"React","Performance","Frontend","# 构建高性能的 React 应用\n\n在现代 Web 开发中，性能优化是一个永恒的话题。本文将分享一些 React 应用性能优化的实践经验。\n\n## 1. 使用 React.memo 避免不必要的重渲染\n\n```jsx\nconst ExpensiveComponent = React.memo(({ data }) => {\n  return \u003Cdiv>{/* 复杂的渲染逻辑 */}\u003C/div>\n})\n```\n\n## 2. 合理使用 useMemo 和 useCallback\n\n```jsx\nconst memoizedValue = useMemo(() => {\n  return computeExpensiveValue(a, b)\n}, [a, b])\n```\n\n## 3. 虚拟列表处理大数据\n\n对于大量数据的渲染，使用虚拟列表可以显著提升性能。\n\n## 总结\n\n性能优化是一个持续的过程，需要在开发中不断实践和总结。","src/content/coding/first-post.md","da4d16c34ddea0f6",{"html":57,"metadata":58},"\u003Ch1 id=\"构建高性能的-react-应用\">构建高性能的 React 应用\u003C/h1>\n\u003Cp>在现代 Web 开发中，性能优化是一个永恒的话题。本文将分享一些 React 应用性能优化的实践经验。\u003C/p>\n\u003Ch2 id=\"1-使用-reactmemo-避免不必要的重渲染\">1. 使用 React.memo 避免不必要的重渲染\u003C/h2>\n\u003Cpre class=\"astro-code github-dark\" style=\"background-color:#24292e;color:#e1e4e8; overflow-x: auto;\" tabindex=\"0\" data-language=\"jsx\">\u003Ccode>\u003Cspan class=\"line\">\u003Cspan style=\"color:#F97583\">const\u003C/span>\u003Cspan style=\"color:#79B8FF\"> ExpensiveComponent\u003C/span>\u003Cspan style=\"color:#F97583\"> =\u003C/span>\u003Cspan style=\"color:#E1E4E8\"> React.\u003C/span>\u003Cspan style=\"color:#B392F0\">memo\u003C/span>\u003Cspan style=\"color:#E1E4E8\">(({ \u003C/span>\u003Cspan style=\"color:#FFAB70\">data\u003C/span>\u003Cspan style=\"color:#E1E4E8\"> }) \u003C/span>\u003Cspan style=\"color:#F97583\">=>\u003C/span>\u003Cspan style=\"color:#E1E4E8\"> {\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#F97583\">  return\u003C/span>\u003Cspan style=\"color:#E1E4E8\"> &#x3C;\u003C/span>\u003Cspan style=\"color:#85E89D\">div\u003C/span>\u003Cspan style=\"color:#E1E4E8\">>{\u003C/span>\u003Cspan style=\"color:#6A737D\">/* 复杂的渲染逻辑 */\u003C/span>\u003Cspan style=\"color:#E1E4E8\">}&#x3C;/\u003C/span>\u003Cspan style=\"color:#85E89D\">div\u003C/span>\u003Cspan style=\"color:#E1E4E8\">>\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#E1E4E8\">})\u003C/span>\u003C/span>\u003C/code>\u003C/pre>\n\u003Ch2 id=\"2-合理使用-usememo-和-usecallback\">2. 合理使用 useMemo 和 useCallback\u003C/h2>\n\u003Cpre class=\"astro-code github-dark\" style=\"background-color:#24292e;color:#e1e4e8; overflow-x: auto;\" tabindex=\"0\" data-language=\"jsx\">\u003Ccode>\u003Cspan class=\"line\">\u003Cspan style=\"color:#F97583\">const\u003C/span>\u003Cspan style=\"color:#79B8FF\"> memoizedValue\u003C/span>\u003Cspan style=\"color:#F97583\"> =\u003C/span>\u003Cspan style=\"color:#B392F0\"> useMemo\u003C/span>\u003Cspan style=\"color:#E1E4E8\">(() \u003C/span>\u003Cspan style=\"color:#F97583\">=>\u003C/span>\u003Cspan style=\"color:#E1E4E8\"> {\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#F97583\">  return\u003C/span>\u003Cspan style=\"color:#B392F0\"> computeExpensiveValue\u003C/span>\u003Cspan style=\"color:#E1E4E8\">(a, b)\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#E1E4E8\">}, [a, b])\u003C/span>\u003C/span>\u003C/code>\u003C/pre>\n\u003Ch2 id=\"3-虚拟列表处理大数据\">3. 虚拟列表处理大数据\u003C/h2>\n\u003Cp>对于大量数据的渲染，使用虚拟列表可以显著提升性能。\u003C/p>\n\u003Ch2 id=\"总结\">总结\u003C/h2>\n\u003Cp>性能优化是一个持续的过程，需要在开发中不断实践和总结。\u003C/p>",{"headings":59,"localImagePaths":73,"remoteImagePaths":74,"frontmatter":45,"imagePaths":75},[60,62,65,68,71],{"depth":27,"slug":61,"text":46},"构建高性能的-react-应用",{"depth":30,"slug":63,"text":64},"1-使用-reactmemo-避免不必要的重渲染","1. 使用 React.memo 避免不必要的重渲染",{"depth":30,"slug":66,"text":67},"2-合理使用-usememo-和-usecallback","2. 合理使用 useMemo 和 useCallback",{"depth":30,"slug":69,"text":70},"3-虚拟列表处理大数据","3. 虚拟列表处理大数据",{"depth":30,"slug":72,"text":72},"总结",[],[],[],"first-post.md"]